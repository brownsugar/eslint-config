{
  "name": "@brownsugar/eslint-config",
  "version": "3.3.0",
  "description": "Preferred ESLint configs for myself.",
  "author": "Lay",
  "license": "MIT",
  "homepage": "https://github.com/brownsugar/eslint-config",
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint . --fix",
    "postversion": "git push && git push --tags"
  },
  "exports": {
    ".": {
      "import": "./dist/typescript.mjs",
      "types": "./dist/typescript.d.ts"
    },
    "./typescript": {
      "import": "./dist/typescript.mjs",
      "types": "./dist/typescript.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.mjs",
      "types": "./dist/vue.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "types": "./dist/nuxt.d.ts"
    }
  },
  "module": "./dist/typescript.mjs",
  "types": "./dist/typescript.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brownsugar/eslint-config.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "rollup": "^4.60.4",
    "rollup-plugin-typescript2": "^0.37.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@nuxt/eslint-config": "^1.15.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.0"
  },
  "peerDependencies": {
    "eslint": "^10",
    "nuxt": "^3 || ^4",
    "vue": "^3"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.5.0"
}
